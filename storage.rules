rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    // Tour images - organized by user
    match /tours/{userId}/{imageId} {
      // Anyone can read tour images
      allow read: if true;

      // Only the owner can upload/delete their tour images
      allow write: if isAuthenticated() && request.auth.uid == userId;

      // Validate file type and size on create
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // User profile images (if needed in future)
    match /profiles/{userId}/{imageId} {
      allow read: if true;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
